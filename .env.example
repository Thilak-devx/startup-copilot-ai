# ─────────────────────────────────────────────────────────────────────────────
# Startup Copilot AI — Environment Configuration Template
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env file; it is git-ignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Cloud / Vertex AI ──────────────────────────────────────────────────
# Required for live LLM runs via Vertex AI.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# ── Google Gemini API ─────────────────────────────────────────────────────────
# Alternative to Vertex AI for direct Gemini API access.
# Only one of GOOGLE_CLOUD_PROJECT or GOOGLE_API_KEY is required.
GOOGLE_API_KEY=your-gemini-api-key-here

# ── Vertex AI Credentials ─────────────────────────────────────────────────────
# Path to your GCP service account JSON key file, if used.
# Leave blank if using Application Default Credentials (gcloud auth).
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── Agent Configuration ───────────────────────────────────────────────────────
# Controls whether the agent runtime uses VertexAI (True) or Gemini API (False)
GOOGLE_GENAI_USE_VERTEXAI=False

# ── Application Settings ──────────────────────────────────────────────────────
# Port for the FastAPI frontend server
APP_PORT=8080
